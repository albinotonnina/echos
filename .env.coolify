# EchOS Environment Configuration for Coolify
# Copy this file to .env and fill in the values

# Required
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=

# LLM provider — Groq with GPT-OSS 120B
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
DEFAULT_MODEL=openai/gpt-oss-120b

# Speech-to-Text — Groq Whisper
STT_API_KEY=
STT_BASE_URL=https://api.groq.com/openai/v1
STT_MODEL=whisper-large-v3-turbo

# Context window — Groq free tier has 8K TPM limit
MAX_CONTEXT_TOKENS=6000

# Optional (needed for embeddings, Whisper)
OPENAI_API_KEY=

# Redis (required — background scheduler, digests, reminders)
REDIS_URL=redis://redis:6379

# Storage paths (inside container)
ECHOS_HOME=/data
KNOWLEDGE_DIR=/data/knowledge
DB_PATH=/data/db
SESSION_DIR=/data/sessions
BACKUP_DIR=/data/backups

# LLM settings
# Prompt cache TTL. 'none' for Groq (only Anthropic supports caching)
CACHE_RETENTION=none
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Interfaces
ENABLE_TELEGRAM=true
ENABLE_WEB=true
TELEGRAM_REACTIONS=true

# Web UI
WEB_PORT=3000
WEB_API_KEY=your-secure-web-api-key-here

# Automated backups
BACKUP_ENABLED=true
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_COUNT=7

# Debug
LOG_LLM_PAYLOADS=false
